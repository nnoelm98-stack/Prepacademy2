      <div class="q-text">Which expression is equivalent?</div>
      <div class="opts" id="opts-2"><div class="opt" onclick="pick(2,this,'A')"><span class="opt-l">A</span>5 / (x² + 2x)</div><div class="opt" onclick="pick(2,this,'B')"><span class="opt-l">B</span>(5x + 4) / (x² + 2x)</div><div class="opt" onclick="pick(2,this,'C')"><span class="opt-l">C</span>(5x + 4) / (2x + 2)</div><div class="opt" onclick="pick(2,this,'D')"><span class="opt-l">D</span>5 / (2x + 2)</div></div>
      <div class="q-actions">
