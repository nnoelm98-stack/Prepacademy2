<body>
<div class="topbar">
  <div class="bc">PrepAcademy › SAT Math › Module 3 › <span>Lesson 3.18</span></div>
  <div class="score-row"><div class="pip" id="pip-0"></div><div class="pip" id="pip-1"></div><div class="pip" id="pip-2"></div></div>
</div>
<div class="prog-wrap">
