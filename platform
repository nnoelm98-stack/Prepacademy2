<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PrepAcademy — SAT Prep</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0C1321;
    --surface: #131E2E;
    --surface2: #1A2640;
    --blue: #4B8EF5;
    --blue-dim: rgba(75,142,245,0.12);
    --blue-border: rgba(75,142,245,0.25);
    --text: #EEF2F8;
    --text2: #8896AA;
    --text3: #5A6A7E;
    --border: rgba(255,255,255,0.06);
    --border2: rgba(255,255,255,0.1);
    --radius: 14px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  a { text-decoration: none; color: inherit; }
  img { display: block; }

  /* ── NAV ── */
  nav {
    position: sticky; top: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 5%;
    height: 64px;
    background: rgba(12,19,33,0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }
  .logo {
    font-family: 'Syne', sans-serif;
    font-size: 19px; font-weight: 800;
    letter-spacing: -0.3px;
  }
  .logo em { color: var(--blue); font-style: normal; }
  .nav-right { display: flex; align-items: center; gap: 10px; }
  .btn-ghost {
    padding: 8px 18px;
    border: 1px solid var(--border2);
    border-radius: 8px;
    font-size: 14px; font-weight: 500;
    color: var(--text2);
    background: transparent;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: color .15s, border-color .15s;
  }
  .btn-ghost:hover { color: var(--text); border-color: var(--border2); }
  .btn-cta {
    padding: 8px 20px;
    background: var(--blue);
    color: #fff;
    border: none; border-radius: 8px;
    font-size: 14px; font-weight: 500;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: opacity .15s;
  }
  .btn-cta:hover { opacity: .88; }

  /* ── HERO ── */
  .hero {
    padding: 80px 5% 72px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    top: -120px; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 500px;
    background: radial-gradient(ellipse at center, rgba(75,142,245,.13) 0%, transparent 65%);
    pointer-events: none;
  }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 7px;
    background: var(--blue-dim);
    border: 1px solid var(--blue-border);
    border-radius: 99px;
    padding: 5px 14px;
    font-size: 13px; font-weight: 500; color: var(--blue);
    margin-bottom: 28px;
  }
  .hero-eyebrow::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--blue); }
  .hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(38px, 5.5vw, 68px);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -2px;
    margin-bottom: 22px;
    max-width: 820px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero h1 .accent { color: var(--blue); }
  .hero-sub {
    font-size: 17px;
    color: var(--text2);
    max-width: 520px;
    margin: 0 auto 36px;
    line-height: 1.72;
  }
  .hero-actions { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
  .btn-hero-primary {
    padding: 14px 30px;
    background: var(--blue);
    color: #fff;
    border: none; border-radius: 10px;
    font-size: 16px; font-weight: 500;
    cursor: pointer; font-family: 'DM Sans', sans-serif;
    transition: opacity .15s;
  }
  .btn-hero-primary:hover { opacity: .88; }
  .btn-hero-secondary {
    padding: 14px 30px;
    background: transparent;
    border: 1px solid var(--border2);
    color: var(--text2);
    border-radius: 10px;
    font-size: 16px;
    cursor: pointer; font-family: 'DM Sans', sans-serif;
    transition: color .15s, border-color .15s;
  }
  .btn-hero-secondary:hover { color: var(--text); border-color: rgba(255,255,255,.2); }

  /* ── SECTION WRAPPER ── */
  .section { padding: 72px 5%; }
  .section-eyebrow {
    font-size: 12px; font-weight: 600; letter-spacing: .1em;
    text-transform: uppercase; color: var(--blue);
    margin-bottom: 10px;
  }
  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(24px, 3.5vw, 38px);
    font-weight: 700;
    letter-spacing: -1px;
    margin-bottom: 14px;
  }
  .section-sub {
    font-size: 16px; color: var(--text2);
    max-width: 520px; margin-bottom: 40px;
    line-height: 1.7;
  }

  /* ── MODULES ── */
  .modules-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); gap: 14px; }
  .mod-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem;
    transition: border-color .2s, transform .2s;
  }
  .mod-card:hover { border-color: var(--blue-border); transform: translateY(-2px); }
  .mod-icon {
    width: 42px; height: 42px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; margin-bottom: 14px;
  }
  .mod-label {
    font-size: 11px; font-weight: 600;
    letter-spacing: .07em; text-transform: uppercase;
    margin-bottom: 5px;
  }
  .mod-name {
    font-family: 'Syne', sans-serif;
    font-size: 15px; font-weight: 600;
    margin-bottom: 6px;
  }
  .mod-desc { font-size: 12px; color: var(--text2); line-height: 1.55; }
  .mod-count { font-size: 12px; color: var(--text3); margin-top: 10px; }

  /* ── HOW IT WORKS ── */
  .steps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 14px; }
  .step-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem;
  }
  .step-number {
    font-family: 'Syne', sans-serif;
    font-size: 28px; font-weight: 800;
    color: var(--blue); opacity: .35;
    margin-bottom: 10px;
  }
  .step-title { font-size: 15px; font-weight: 500; margin-bottom: 6px; }
  .step-body { font-size: 13px; color: var(--text2); line-height: 1.6; }

  /* ── LESSON PREVIEW ── */
  .preview-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
  }
  .preview-topbar {
    padding: 12px 16px;
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 10px;
  }
  .preview-dots { display: flex; gap: 5px; }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .preview-title-bar { font-size: 12px; color: var(--text3); flex: 1; text-align: center; }
  .preview-body { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
  .preview-passage {
    padding: 1.25rem 1.25rem;
    border-right: 1px solid var(--border);
    font-size: 13px; line-height: 1.85; color: var(--text2);
  }
  .preview-source { font-size: 11px; color: var(--text3); font-style: italic; margin-bottom: 10px; }
  .preview-hl { background: rgba(75,142,245,.18); border-radius: 3px; padding: 0 3px; color: var(--text); }
  .preview-q { padding: 1.25rem; display: flex; flex-direction: column; gap: 10px; }
  .preview-q-label { font-size: 10px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--blue); }
  .preview-q-text { font-size: 13px; line-height: 1.55; }
  .preview-opt {
    font-size: 12px; padding: 8px 11px; border-radius: 7px;
    border: 1px solid var(--border); color: var(--text2);
    display: flex; align-items: center; gap: 8px;
  }
  .preview-opt.sel { border-color: var(--blue); background: var(--blue-dim); color: var(--blue); }
  .preview-opt.sel .ol { background: var(--blue); color: #fff; }
  .ol {
    width: 18px; height: 18px; border-radius: 50%; background: var(--surface2);
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 600; flex-shrink: 0;
  }

  /* ── PRICING ── */
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr)); gap: 14px; max-width: 820px; }
  .price-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    position: relative;
  }
  .price-card.featured { border-color: var(--blue); }
  .popular-badge {
    position: absolute; top: -11px; left: 50%; transform: translateX(-50%);
    background: var(--blue); color: #fff;
    font-size: 11px; font-weight: 600;
    padding: 3px 12px; border-radius: 99px;
    white-space: nowrap;
  }
  .price-name { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; margin-bottom: 6px; }
  .price-amount { font-family: 'Syne', sans-serif; font-size: 38px; font-weight: 800; line-height: 1; margin-bottom: 3px; }
