    <div class="result-bars">
      <div class="r-row"><span class="r-label">Information & Ideas</span><div class="r-track"><div class="r-fill" style="width:60%"></div></div><span style="font-size:12px;color:var(--text2);">60%</span></div>
      <div class="r-row"><span class="r-label">Expression & Conventions</span><div class="r-track"><div class="r-fill" style="width:40%"></div></div><span style="font-size:12px;color:var(--text2);">40%</span></div>
      <div class="r-row"><span class="r-label">Math — Algebra</span><div class="r-track"><div class="r-fill" style="width:80%"></div></div><span style="font-size:12px;color:var(--text2);">80%</span></div>
    </div>
    <button class="btn-main" style="margin-top:1.5rem" onclick="location.href='dashboard.html'">Start studying →</button>
  </div>
</div>

<script>
const steps = ['CREATE YOUR ACCOUNT','CHOOSE YOUR EXAM','SET YOUR TARGET','QUICK DIAGNOSTIC','YOUR PLAN IS READY'];
const pcts = [20,40,60,80,100];
let diagStep = 0;
const diagQs = [
  {q:'The central idea of a passage is best described as:', opts:['The first sentence of the first paragraph','The main point the author makes throughout the passage','A supporting detail that appears multiple times','The conclusion of the final paragraph'], ans:1},
  {q:'Which word choice correctly completes this sentence? "The team _____ their strategy after the first half."', opts:['revised','revising','have revise','to revise'], ans:0},
  {q:'Solve for x: 3x + 7 = 22', opts:['x = 3','x = 5','x = 7','x = 9'], ans:1},
  {q:'If y = 2x − 3, what is y when x = 4?', opts:['y = 2','y = 5','y = 8','y = 11'], ans:1},
  {q:'Which transition best connects these ideas: "The experiment failed. _____, the team learned valuable lessons."', opts:['Therefore','Nevertheless','Furthermore','In contrast'], ans:1}
];

function goStep(n) {
  document.querySelectorAll('.step').forEach(s=>s.classList.remove('active'));
  document.getElementById('s'+n).classList.add('active');
  document.getElementById('progress').style.width = pcts[n-1]+'%';
  document.getElementById('step-label').textContent = 'STEP '+n+' OF 5 — '+steps[n-1];
  if(n===4) loadDiag();
}

function selectExam(el) {
  document.querySelectorAll('.exam-card').forEach(e=>e.classList.remove('selected'));
  el.classList.add('selected');
}

function loadDiag() {
  diagStep = 0;
  updateDiag();
}

function updateDiag() {
  const d = diagQs[diagStep];
  document.getElementById('diag-q').textContent = d.q;
  const optsEl = document.getElementById('diag-opts');
  optsEl.innerHTML = d.opts.map((o,i)=>`<div class="diag-opt" onclick="answerDiag(this,${i===d.ans})">${o}</div>`).join('');
  const dots = document.querySelectorAll('.diag-dot');
  dots.forEach((d,i)=>{ d.className='diag-dot'; if(i<diagStep)d.classList.add('done'); if(i===diagStep)d.classList.add('current'); });
}

function answerDiag(el, correct) {
  document.querySelectorAll('.diag-opt').forEach(o=>o.onclick=null);
  el.classList.add(correct?'correct':'wrong');
  if(!correct) {
    const d = diagQs[diagStep];
    document.querySelectorAll('.diag-opt')[d.ans].classList.add('correct');
  }
  setTimeout(()=>{
    diagStep++;
    if(diagStep>=5) { goStep(5); return; }
    updateDiag();
  }, 900);
}
</script>
</body>
</html>
